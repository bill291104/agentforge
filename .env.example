# Anthropic
ANTHROPIC_API_KEY=your_key_here

# LangSmith (제로-설정 트레이싱 — LANGCHAIN_TRACING_V2=true 만으로 활성화)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=agentforge

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# 모델 설정
AF_LEADER_MODEL=claude-opus-4-7
AF_ORCHESTRATOR_MODEL=claude-sonnet-4-6
AF_WORKER_MODEL=claude-haiku-4-5-20251001

# 컨텍스트 임계값
AF_CONTEXT_COMPRESS_PCT=0.70
AF_CONTEXT_SPAWN_PCT=0.90

# ObserverAgent
AF_RETROSPECT_SESSION_COUNT=10
AF_RETROSPECT_FAILURE_THRESHOLD=0.30

# Docker 샌드박스
AF_SANDBOX_IMAGE=python:3.11-slim
AF_SANDBOX_MEMORY=512m
AF_SANDBOX_CPUS=1

# 데이터베이스 (체크포인트)
AF_DB_PATH=agentforge.db

# 개발
AF_MOCK_MODE=false
AF_LOG_LEVEL=INFO
